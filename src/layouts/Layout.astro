---
const { title, description } = Astro.props;
import "@/styles/global.css";
import HeaderAstroComponent from "@/components/Layout/Header.astro";
import FooterAstroComponent from "@/components/Layout/Footer.astro";
---

<!doctype html>
<html lang="es" data-theme="light">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" href="/pibble_favicon.png" />
        <link rel="icon" href="/pibble_favicon.png" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head><body>
        <div class="max-w-5xl mx-auto" id="super">
            <HeaderAstroComponent />
            <main>
                <slot />
            </main>

            <FooterAstroComponent />
        </div>
    </body>
</html>

<style>
    @import url("https://fonts.googleapis.com/css2?family=Onest:wght@100..900&display=swap");

    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
        font-family: "Onest", sans-serif;
    }

    #super {
        height: 100dvh;
        display: grid;
        grid-template-rows: auto 1fr auto;
    }
</style>
